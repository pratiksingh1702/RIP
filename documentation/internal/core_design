# gateway/gateway/core/events/bus.py

from typing import Any, Callable, Dict, List
import asyncio
from datetime import datetime
import uuid

class EventBus:
    """
    Lightweight pub/sub event bus.
    
    Subscribers register for event types.
    When an event is emitted, all matching subscribers are called.
    
    Also persists events to the database for replay/audit.
    """
    
    def __init__(self, storage):
        self.subscribers: Dict[str, List[Callable]] = {}  # event_type -> [callbacks]
        self.storage = storage
    
    def subscribe(self, event_type: str, callback: Callable) -> None:
        """Register a callback for an event type."""
        if event_type not in self.subscribers:
            self.subscribers[event_type] = []
        self.subscribers[event_type].append(callback)
    
    def emit(self, event: Dict[str, Any]) -> None:
        """Emit an event to all subscribers."""
        event.setdefault("id", str(uuid.uuid4()))
        event.setdefault("ts", datetime.utcnow().isoformat())
        
        event_type = event.get("type", "unknown")
        
        # Notify subscribers (fire and forget)
        for callback in self.subscribers.get(event_type, []):
            try:
                callback(event)
            except Exception as e:
                # Log but don't crash
                print(f"Event subscriber error for {event_type}: {e}")
        
        # Notify wildcard subscribers
        for callback in self.subscribers.get("*", []):
            try:
                callback(event)
            except Exception:
                pass
        
        # Persist to database (async, non-blocking)
        asyncio.create_task(self._persist_event(event))
    
    async def _persist_event(self, event: Dict[str, Any]) -> None:
        """Persist event to database for audit/replay."""
        await self.storage.insert_audit_event(event)
