from jinja2 import Environment, BaseLoader, TemplateSyntaxError, UndefinedError
from typing import Any, Dict, Optional
import json

class PromptEngine:
    """
    Renders prompt templates with variable substitution.
    
    Uses Jinja2 for template rendering.
    Supports:
    - {{variable}} simple substitution
    - {{step_1.output.top_result}} drill-down
    - {% if condition %}...{% endif %} conditionals
    - {% for item in list %}...{% endfor %} loops
    - {{ value | filter_name }} filters
    """
    
    def __init__(self):
        self.env = Environment(
            loader=BaseLoader(),
            undefined=lambda: None,  # Return None for undefined vars instead of raising
        )
        self._register_filters()
    
    def render(
        self,
        template: str,
        context: Dict[str, Any],
        strict: bool = False,
    ) -> str:
        """
        Render a template with the given context.
        
        Args:
            template: Jinja2 template string
            context: Variables available in the template
            strict: If True, raise on undefined variables
        
        Returns:
            Rendered string
        """
        if strict:
            self.env.undefined = UndefinedError
        
        try:
            jinja_template = self.env.from_string(template)
            return jinja_template.render(**context)
        except TemplateSyntaxError as e:
            raise ValueError(f"Template syntax error: {e}")
        except UndefinedError as e:
            raise ValueError(f"Undefined variable in template: {e}")
    
    def render_prompt_template(
        self,
        template_record: Dict,
        step_outputs: Dict[str, Any],
        trigger_params: Dict[str, Any],
        workflow_context: Dict[str, Any],
    ) -> Dict[str, str]:
        """
        Render both system and user prompts from a template record.
        
        Returns:
            {"system_prompt": "...", "user_prompt": "..."}
        """
        # Build full context
        context = {
            **trigger_params,
            **workflow_context,
        }
        
        # Add step outputs as step_1, step_2, etc.
        for step_id, output in step_outputs.items():
            context[step_id] = output
        
        system_prompt = self.render(template_record.get("system_prompt", ""), context)
        user_prompt = self.render(template_record.get("user_prompt_template", ""), context)
        
        return {
            "system_prompt": system_prompt,
            "user_prompt": user_prompt,
        }
    
    def extract_variables(self, template: str) -> List[str]:
        """Extract all variable names from a template."""
        from jinja2 import meta
        ast = self.env.parse(template)
        return list(meta.find_undeclared_variables(ast))
    
    def _register_filters(self):
        """Register custom Jinja2 filters."""
        self.env.filters['json'] = json.dumps
        self.env.filters['code_block'] = lambda s, lang="": f"```{lang}\n{s}\n```"
