```python
# gateway/gateway/core/workflow/input_resolver.py

from typing import Any, Dict, List, Optional
import re

class InputResolver:
    """
    Resolves input bindings to actual values at runtime.
    
    Handles:
    - trigger_query: full text query from user
    - trigger_param: named parameter from trigger configuration
    - step_output: value from a completed step's output (with JSON path)
    - fixed: literal value set at design time
    - composite: combines multiple sources
    """
    
    def resolve(
        self,
        bindings: List[Dict],
        trigger_params: Dict[str, Any],
        step_outputs: Dict[str, Any],
    ) -> Dict[str, Any]:
        """Resolve all input bindings for a block."""
        resolved = {}
        
        for binding in bindings:
            field = binding["input_field"]
            source = binding["source"]
            
            value = self._resolve_single(binding, trigger_params, step_outputs)
            resolved[field] = value
        
        return resolved
    
    def _resolve_single(
        self,
        binding: Dict,
        trigger_params: Dict,
        step_outputs: Dict,
    ) -> Any:
        source = binding["source"]
        
        if source == "trigger_query":
            return trigger_params.get("query", "")
        
        elif source == "trigger_param":
            param_name = binding.get("param_name") or binding["input_field"]
            value = trigger_params.get(param_name)
            if value is None and binding.get("default_value"):
                value = binding["default_value"]
            return value
        
        elif source == "step_output":
            source_step = binding["source_step_id"]
            source_field = binding.get("source_field", "")
            
            step_output = step_outputs.get(source_step, {})
            
            if not source_field or source_field == "*":
                return step_output
            
            # JSON path drilling: "top_result.files[0].path"
            return self._drill_json_path(step_output, source_field)
        
        elif source == "fixed":
            return binding.get("fixed_value")
        
        elif source == "composite":
            # Combine multiple sub-sources
            parts = {}
            for sub_binding in binding.get("parts", []):
                parts[sub_binding["name"]] = self._resolve_single(
                    sub_binding, trigger_params, step_outputs
                )
            return parts
        
        return None
    
    def _drill_json_path(self, obj: Any, path: str) -> Any:
        """
        Drill into an object using dot/bracket notation.
        Examples:
        - "top_result" → obj["top_result"]
        - "files[0]" → obj["files"][0]
        - "top_result.files[0].path" → obj["top_result"]["files"][0]["path"]
        """
        if not path:
            return obj
        
        # Tokenize: split on dots and brackets
        tokens = re.findall(r'\w+|\[\d+\]', path)
        
        current = obj
        for token in tokens:
            if current is None:
                return None
            
            if token.startswith('['):
                # Array index
                index = int(token[1:-1])
                if isinstance(current, list) and index < len(current):
                    current = current[index]
                else:
                    return None
            else:
                # Object key
                if isinstance(current, dict):
                    current = current.get(token)
                elif hasattr(current, token):
                    current = getattr(current, token)
                else:
                    return None
        
        return current
