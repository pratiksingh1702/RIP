### 4.2 MCP Sources → Block Registry Sync

```python
def register_mcp_tool_blocks():
    """
    For every registered MCP source with usable_as=['tool_action'],
    create corresponding block entries in the registry.
    """
    sources = db.list_registered_sources()
    
    for source in sources:
        if "tool_action" in source.get("usable_as", []):
            # For each tool in the MCP server, create a block
            tools = mcp_client.list_tools(source)
            for tool in tools:
                block = MCPToolBlock(
                    source=source,
                    tool_name=tool["name"],
                    tool_description=tool.get("description", ""),
                    input_schema=tool.get("inputSchema", {}),
                )
                block_registry.register(block)
```

