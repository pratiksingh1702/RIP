    category VARCHAR(50), -- investigation, implementation, audit, maintenance, onboarding, custom
    version VARCHAR(20) DEFAULT '1.0.0',
    
    -- Source: 'draft' = canvas-built, 'template' = from template, 'imported' = from JSON/YAML
    source VARCHAR(20) DEFAULT 'draft',
