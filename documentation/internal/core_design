# gateway/gateway/core/workflow/engine.py

from dataclasses import dataclass, field
from enum import Enum
from typing import Any, Dict, List, Optional
import asyncio
import uuid

class WorkflowRunStatus(str, Enum):
    PENDING = "pending"
    RUNNING = "running"
    AWAITING_APPROVAL = "awaiting_approval"
    AWAITING_INPUT = "awaiting_input"
    COMPLETED = "completed"
    FAILED = "failed"
    REJECTED = "rejected"
    CANCELLED = "cancelled"

@dataclass
class WorkflowRun:
    id: str
    workflow_id: str
    status: WorkflowRunStatus
    current_step_id: Optional[str]
    trigger_input: Dict
    resolved_params: Dict
    steps: Dict[str, "StepState"]  # step_id -> StepState
    event_bus: Any
    
    def get_step_output(self, step_id: str, field_path: Optional[str] = None) -> Any:
        """Get a step's output, optionally drilling into a field path."""
        step = self.steps.get(step_id)
        if not step or not step.output:
            return None
        if field_path:
            return self._drill(step.output, field_path)
        return step.output
    
    def _drill(self, obj: Any, path: str) -> Any:
        """Drill into an object using dot notation: 'top_result.files'"""
        parts = path.split(".")
        current = obj
        for part in parts:
            if isinstance(current, dict):
                current = current.get(part)
            elif hasattr(current, part):
                current = getattr(current, part)
            else:
                return None
        return current


class WorkflowEngine:
    """
    Executes workflow runs.
    
    Responsibilities:
    - Load workflow definition (blocks + wires + triggers)
    - Resolve DAG (topological sort of blocks based on wire connections)
    - Execute each block in order (parallel where possible)
    - Resolve input bindings before each block
    - Handle suspension (approval gates, input required)
    - Handle errors and retries
    - Emit events at every step
    """
    
    def __init__(self, block_registry, event_bus, storage):
        self.block_registry = block_registry
        self.event_bus = event_bus
        self.storage = storage
    
    async def start_run(
        self,
        workflow_id: str,
        trigger_input: Dict[str, Any],
        user_id: str,
        project_id: Optional[str] = None,
    ) -> WorkflowRun:
        """Start a new workflow run."""
        
        # 1. Load workflow definition
        workflow_def = await self.storage.get_workflow_definition(workflow_id)
        if not workflow_def:
            raise ValueError(f"Workflow {workflow_id} not found")
        
        # 2. Create run record
        run = WorkflowRun(
            id=str(uuid.uuid4()),
            workflow_id=workflow_id,
            status=WorkflowRunStatus.PENDING,
            current_step_id=None,
            trigger_input=trigger_input,
            resolved_params={},
            steps={},
            event_bus=self.event_bus,
        )
        
        # 3. Snapshot the workflow definition (immutable for this run)
        workflow_snapshot = {
            "blocks": workflow_def["blocks"],
            "wires": workflow_def["wires"],
            "triggers": workflow_def["triggers"],
            "approval_gates": workflow_def.get("approval_gates", []),
        }
        await self.storage.create_workflow_run(run, workflow_snapshot)
        
        # 4. Emit started event
        self.event_bus.emit({
            "type": "workflow_started",
            "workflow_run_id": run.id,
            "workflow_id": workflow_id,
            "user_id": user_id,
        })
        
        # 5. Resolve trigger parameters
        resolved_params = await self._resolve_trigger_params(
            workflow_def, trigger_input, user_id, project_id
        )
        run.resolved_params = resolved_params
        
        # 6. Build execution DAG
        execution_order = self._build_execution_dag(workflow_def["blocks"], workflow_def["wires"])
        
        # 7. Initialize step states
        for step in execution_order:
            run.steps[step["step_id"]] = StepState(
                step_id=step["step_id"],
                block_type_id=step["block_type_id"],
                status="pending",
                config=step.get("config", {}),
                input_bindings=step.get("input_bindings", []),
            )
        
        # 8. Start execution (async, non-blocking)
        asyncio.create_task(self._execute_run(run, execution_order, user_id, project_id))
        
        return run
    
    async def _execute_run(
        self,
        run: WorkflowRun,
        execution_order: List[Dict],
        user_id: str,
        project_id: Optional[str],
    ):
        """Execute all steps in order."""
        run.status = WorkflowRunStatus.RUNNING
        await self.storage.update_workflow_run(run)
        
        try:
            # Group steps into parallel batches
            batches = self._group_parallel_batches(execution_order)
            
            for batch in batches:
                # Execute all steps in this batch in parallel
                tasks = []
                for step_def in batch:
                    task = self._execute_step(run, step_def, user_id, project_id)
                    tasks.append(task)
                
                results = await asyncio.gather(*tasks, return_exceptions=True)
                
                # Check results
                for i, result in enumerate(results):
                    if isinstance(result, Exception):
                        # Handle step failure
                        await self._handle_step_failure(run, batch[i], result)
                        return
                    
                    if result.status == "suspended":
                        # Approval gate or input required - pause entire workflow
                        run.status = WorkflowRunStatus.AWAITING_APPROVAL
                        await self.storage.update_workflow_run(run)
                        return  # Wait for resume
            
            # All steps completed
            run.status = WorkflowRunStatus.COMPLETED
            await self.storage.update_workflow_run(run)
            
            self.event_bus.emit({
                "type": "workflow_completed",
                "workflow_run_id": run.id,
            })
            
        except Exception as e:
            run.status = WorkflowRunStatus.FAILED
            run.error_message = str(e)
            await self.storage.update_workflow_run(run)
            
            self.event_bus.emit({
                "type": "workflow_failed",
                "workflow_run_id": run.id,
                "error": str(e),
            })
    
    async def _execute_step(
        self,
        run: WorkflowRun,
        step_def: Dict,
        user_id: str,
        project_id: Optional[str],
    ) -> BlockResult:
        """Execute a single step."""
        step_id = step_def["step_id"]
        step_state = run.steps[step_id]
        
        # 1. Update status
        step_state.status = "running"
        run.current_step_id = step_id
        await self.storage.update_workflow_run_step(run.id, step_state)
        
        # 2. Emit event
        self.event_bus.emit({
            "type": "step_started",
            "workflow_run_id": run.id,
            "step_id": step_id,
            "block_type_id": step_def["block_type_id"],
        })
        
        # 3. Resolve inputs from bindings
        resolved_inputs = self._resolve_input_bindings(
            step_def.get("input_bindings", []),
            run,
            run.resolved_params,
        )
        
        # 4. Get block instance
        block = self.block_registry.get_block_instance(step_def["block_type_id"])
        
        # 5. Create execution context
        ctx = ExecutionContext(
            user_id=user_id,
            project_id=project_id,
            workflow_run_id=run.id,
            step_id=step_id,
            session_id=None,
            event_bus=self.event_bus,
            storage=self.storage,
            api_key="...",  # From user context
        )
        
        # 6. Execute with retry
        max_retries = step_def.get("max_retries", 3)
        for attempt in range(max_retries + 1):
            try:
                result = await asyncio.wait_for(
                    block.run(ctx, resolved_inputs, step_def.get("config", {})),
                    timeout=step_def.get("timeout_ms", 300000) / 1000,
                )
                break
            except asyncio.TimeoutError:
                if attempt == max_retries:
                    result = BlockResult(
                        ok=False,
                        status=BlockStatus.FAILED,
                        error="Step timed out",
                        error_type="timeout",
                    )
                else:
                    await asyncio.sleep(step_def.get("retry_delay_ms", 1000) / 1000)
            except Exception as e:
                if attempt == max_retries:
                    result = BlockResult(
                        ok=False,
                        status=BlockStatus.FAILED,
                        error=str(e),
                        error_type="execution_error",
                    )
        
        # 7. Update step state
        step_state.status = result.status.value
        step_state.output = result.output
        step_state.error = result.error
        step_state.tokens_used = result.tokens_used
        step_state.cost_cents = result.cost_cents
        await self.storage.update_workflow_run_step(run.id, step_state)
        
        # 8. Emit event
        self.event_bus.emit({
            "type": "step_completed" if result.ok else "step_failed",
            "workflow_run_id": run.id,
            "step_id": step_id,
            "result": result,
        })
        
        return result
    
    def _resolve_input_bindings(
        self,
        bindings: List[Dict],
        run: WorkflowRun,
        trigger_params: Dict,
    ) -> Dict[str, Any]:
        """
        Resolve input bindings to actual values.
        
        Binding sources:
        - "trigger_query": value extracted from the user's query
        - "step_output": value from a previous step's output
        - "fixed": literal value set at design time
        - "trigger_param": named parameter from trigger configuration
        """
        resolved = {}
        
        for binding in bindings:
            field = binding["input_field"]
            source = binding["source"]
            
            if source == "trigger_query":
                # The full query text
                resolved[field] = trigger_params.get("query", "")
                
            elif source == "trigger_param":
                # Named parameter from trigger config
                param_name = binding.get("param_name", field)
                resolved[field] = trigger_params.get(param_name)
                
            elif source == "step_output":
                # Output from a previous step
                source_step = binding["source_step_id"]
                source_field = binding.get("source_field")
                value = run.get_step_output(source_step, source_field)
                resolved[field] = value
                
            elif source == "fixed":
                # Literal value
                resolved[field] = binding.get("fixed_value")
        
        return resolved
    
    def _build_execution_dag(
        self,
        blocks: List[Dict],
        wires: List[Dict],
    ) -> List[Dict]:
        """
        Build a topologically sorted execution order from blocks and wires.
        
        Wires define dependencies:
        - A wire from block A to block B means B depends on A
        - Blocks with no incoming wires are root nodes (depend only on trigger)
        - Blocks with multiple incoming wires depend on all sources
        """
        # Build adjacency list
        dependencies = {}  # block_id -> [block_ids it depends on]
        for block in blocks:
            dependencies[block["step_id"]] = []
        
        for wire in wires:
            target = wire["target_block_id"]
            source = wire["source_block_id"]
            # Find step_ids
            target_step = next(b["step_id"] for b in blocks if b["id"] == target)
            source_step = next(b["step_id"] for b in blocks if b["id"] == source)
            if source_step not in dependencies[target_step]:
                dependencies[target_step].append(source_step)
        
        # Topological sort (Kahn's algorithm)
        in_degree = {step: len(deps) for step, deps in dependencies.items()}
        queue = [step for step, deg in in_degree.items() if deg == 0]
        sorted_steps = []
        
        while queue:
            step = queue.pop(0)
            sorted_steps.append(step)
            # Reduce in-degree of dependents
            for dependent, deps in dependencies.items():
                if step in deps:
                    in_degree[dependent] -= 1
                    if in_degree[dependent] == 0:
                        queue.append(dependent)
        
        # Map back to full block definitions
        block_map = {b["step_id"]: b for b in blocks}
        return [block_map[step_id] for step_id in sorted_steps]
    
    def _group_parallel_batches(self, execution_order: List[Dict]) -> List[List[Dict]]:
        """
        Group steps into parallel batches.
        Steps that don't depend on each other can run in parallel.
        """
        # For now, simple implementation: each step is its own batch
        # Future: detect independent steps and group them
        return [[step] for step in execution_order]
    
    async def resume_run(
        self,
        run_id: str,
        approval_decision: bool,
        approved_by: str,
        comment: Optional[str] = None,
    ) -> WorkflowRun:
        """Resume a suspended workflow run."""
        run = await self.storage.get_workflow_run(run_id)
        
        if run.status not in [WorkflowRunStatus.AWAITING_APPROVAL, WorkflowRunStatus.AWAITING_INPUT]:
            raise ValueError(f"Run {run_id} is not awaiting approval/input")
        
        # Find the suspended step
        suspended_step = None
        for step_id, step_state in run.steps.items():
            if step_state.status == "suspended":
                suspended_step = step_state
                break
        
        if suspended_step:
            suspended_step.output = {
                "approved": approval_decision,
                "approved_by": approved_by,
                "comment": comment or "",
            }
            suspended_step.status = "completed"
            await self.storage.update_workflow_run_step(run.id, suspended_step)
        
        # Resume execution from the next step
        # ... (continue from where we left off)
        
        return run
