### 3.5 WebSocket for Live Run Events

```python
# gateway/gateway/server/websocket/workflow_ws.py

@router.websocket("/ws/workflows/{run_id}")
async def workflow_run_websocket(websocket: WebSocket, run_id: str):
    """Stream live workflow execution events."""
    await websocket.accept()
    
    # Subscribe to events for this run
    event_queue = asyncio.Queue()
    
    async def event_handler(event):
        if event.get("workflow_run_id") == run_id:
            await event_queue.put(event)
    
    event_bus.subscribe("*", event_handler)
    
    try:
        while True:
            event = await event_queue.get()
            await websocket.send_json(event)
    except WebSocketDisconnect:
        pass
    finally:
        event_bus.unsubscribe("*", event_handler)
