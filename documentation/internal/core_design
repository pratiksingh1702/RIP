### 2.2 Block Registry (New File)

```python
# gateway/gateway/core/blocks/registry.py

from typing import Dict, List, Optional, Type
from gateway.core.blocks.base import Block, BlockKind

class BlockRegistry:
    """
    Central registry of all available block types.
    Blocks register themselves at startup.
    The registry is queried by the Workflow Engine and the UI palette.
    """
    
    def __init__(self):
        self._blocks: Dict[str, Block] = {}  # block_id -> Block instance
        self._by_kind: Dict[BlockKind, List[str]] = {}  # kind -> [block_ids]
        self._by_category: Dict[str, List[str]] = {}  # category -> [block_ids]
    
    def register(self, block: Block) -> None:
        """Register a block type."""
        if block.id in self._blocks:
            raise ValueError(f"Block {block.id} already registered")
        
        self._blocks[block.id] = block
        
        # Index by kind
        if block.kind not in self._by_kind:
            self._by_kind[block.kind] = []
        self._by_kind[block.kind].append(block.id)
        
        # Index by category
        if block.category not in self._by_category:
            self._by_category[block.category] = []
        self._by_category[block.category].append(block.id)
        
        # Also persist to block_type_registry table
        self._sync_to_db(block)
    
    def get(self, block_id: str) -> Optional[Block]:
        """Get a block by ID."""
        return self._blocks.get(block_id)
    
    def list_all(self) -> List[Dict]:
        """List all registered blocks (for UI palette)."""
        return [block.describe() for block in self._blocks.values()]
    
    def list_by_kind(self, kind: BlockKind) -> List[Dict]:
        """List blocks of a specific kind."""
        block_ids = self._by_kind.get(kind, [])
        return [self._blocks[bid].describe() for bid in block_ids]
    
    def list_by_category(self, category: str) -> List[Dict]:
        """List blocks in a category."""
        block_ids = self._by_category.get(category, [])
        return [self._blocks[bid].describe() for bid in block_ids]
    
    def get_block_instance(self, block_id: str) -> Block:
        """Get a block instance for execution."""
        block = self._blocks.get(block_id)
        if not block:
            raise ValueError(f"Block {block_id} not found")
        return block
    
    def _sync_to_db(self, block: Block):
        """Ensure block exists in block_type_registry table."""
