# Gateway Server Settings
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8001
GATEWAY_VERSION=0.1.0
GATEWAY_DEBUG=false

# Database Settings (match RIP's setup)
GATEWAY_POSTGRES_URL=postgresql+asyncpg://repo_intel:repo_intel@localhost:5433/repo_intel?ssl=disable
GATEWAY_REDIS_URL=redis://localhost:6379

# RIP MCP Server Settings
GATEWAY_RIP_MCP_COMMAND=uv
GATEWAY_RIP_MCP_ARGS=["run","python","mcp/server.py"]
GATEWAY_RIP_MCP_CWD=.

# GitHub MCP Settings
GATEWAY_GITHUB_MCP_ENABLED=false
GATEWAY_GITHUB_TOKEN=
GATEWAY_GITHUB_REPO=
GATEWAY_GITHUB_API_URL=https://api.github.com

# Jira MCP Settings
GATEWAY_JIRA_MCP_ENABLED=false
GATEWAY_JIRA_URL=
GATEWAY_JIRA_TOKEN=
GATEWAY_JIRA_EMAIL=
GATEWAY_JIRA_PROJECT_KEY=

# Slack MCP Settings
GATEWAY_SLACK_MCP_ENABLED=false
GATEWAY_SLACK_TOKEN=
GATEWAY_SLACK_CHANNEL_ID=

# LLM Settings
GATEWAY_LLM_PROVIDER=google
GATEWAY_LLM_MODEL=gemini-2.5-flash
GATEWAY_LLM_FALLBACK_THRESHOLD=0.70
GATEWAY_LLM_FALLBACK_ENABLED=true
GATEWAY_GOOGLE_API_KEY=AQ.Ab8RN6LmhJFcmrcI7l2Y_hVTZENpCJgFksCPQ9CDvEANRMoBpw

# Token Settings
GATEWAY_DEFAULT_MAX_TOKENS=12000
GATEWAY_MIN_TOKENS_PER_SOURCE=500
GATEWAY_OVERHEAD_RESERVE_RATIO=0.10

# Execution Settings
GATEWAY_SOURCE_TIMEOUT_SECONDS=120.0
GATEWAY_CIRCUIT_BREAKER_THRESHOLD=3
GATEWAY_CIRCUIT_BREAKER_RESET_SECONDS=300

# Cache Settings
GATEWAY_CACHE_TTL_SECONDS=300

# Permissions
GATEWAY_DEFAULT_ROLE=developer
