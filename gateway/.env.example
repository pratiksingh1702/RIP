# Gateway Server Settings
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8001

# Database Settings
GATEWAY_POSTGRES_URL=postgresql+asyncpg://rip_user:rip_pass@localhost:5432/rip_db
GATEWAY_REDIS_URL=redis://localhost:6379/1

# RIP MCP Server Settings
GATEWAY_RIP_MCP_COMMAND=uv
GATEWAY_RIP_MCP_ARGS=["run","python","mcp/server.py"]
GATEWAY_RIP_MCP_CWD=../

# GitHub MCP Settings
GATEWAY_GITHUB_MCP_ENABLED=false
GATEWAY_GITHUB_TOKEN=

# Jira MCP Settings
GATEWAY_JIRA_MCP_ENABLED=false
GATEWAY_JIRA_URL=
GATEWAY_JIRA_TOKEN=

# Slack MCP Settings
GATEWAY_SLACK_MCP_ENABLED=false
GATEWAY_SLACK_TOKEN=

# LLM Settings
GATEWAY_LLM_PROVIDER=ollama
GATEWAY_LLM_MODEL=qwen2.5-coder:7b
GATEWAY_LLM_FALLBACK_THRESHOLD=0.70

# Token Settings
GATEWAY_DEFAULT_MAX_TOKENS=12000
GATEWAY_MIN_TOKENS_PER_SOURCE=500
GATEWAY_OVERHEAD_RESERVE_RATIO=0.10

# Execution Settings
GATEWAY_SOURCE_TIMEOUT_SECONDS=5.0
GATEWAY_CIRCUIT_BREAKER_THRESHOLD=3
GATEWAY_CIRCUIT_BREAKER_RESET_SECONDS=300

# Cache Settings
GATEWAY_CACHE_TTL_SECONDS=300

# Permissions
GATEWAY_DEFAULT_ROLE=developer
