{
  "name": "repo-intelligence",
  "displayName": "Repository Intelligence",
  "description": "Repository Intelligence Platform VS Code extension",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {"command": "repoIntel.trace", "title": "RIP: Trace Symbol"},
      {"command": "repoIntel.impact", "title": "RIP: Impact Analysis"},
      {"command": "repoIntel.explain", "title": "RIP: Explain Symbol"},
      {"command": "repoIntel.showArchitecture", "title": "RIP: Show Architecture"},
      {"command": "repoIntel.showDependencyGraph", "title": "RIP: Show Dependency Graph"}
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "@vscode/webview-ui-toolkit": "^1.4.0"
  }
}
